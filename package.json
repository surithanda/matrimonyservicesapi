{
  "name": "matrimony-enterprise-services-api",
  "version": "1.0.0",
  "description": "Matrimony Enterprise Services API",
  "repository": {
    "type": "git",
    "url": "https://github.com/mysticmind-data-solutions/matrimony-enterprise-services-api.git"
  },
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon",
    "dev:tsnd": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npm run clean && npm run compile",
    "compile": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "watch": "tsc -w",
    "serve": "nodemon dist/index.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "npm run build"
  },
  "keywords": [],
  "author": "MysticMind Data Solutions LLC",
  "license": "ISC",
