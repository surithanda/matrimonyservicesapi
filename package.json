    "@azure/storage-blob": "12.31.0",
    "@elastic/elasticsearch": "8.17.0",
    "@google/generative-ai": "^0.24.1",
    "@types/cookie-parser": "1.4.10",
    "@types/multer": "1.4.12",
    "@types/uuid": "10.0.0",
    "bcrypt": "6.0.0",
    "brcypt": "1.0.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.22.1",
    "express-rate-limit": "6.11.2",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.1",
    "multer": "1.4.5-lts.1",
    "mysql2": "3.12.0",
