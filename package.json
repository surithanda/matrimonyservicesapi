    "openai": "^6.29.0",
    "sharp": "^0.34.5",
    "stripe": "18.5.0",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1",
    "uuid": "11.0.3",
    "winston": "3.17.0",
    "winston-elasticsearch": "0.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.19",
    "@types/express": "4.17.23",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
